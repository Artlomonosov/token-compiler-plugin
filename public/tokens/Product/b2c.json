  "Radius": {
    "control-m": {
      "$extensions": {
        "com.figma.scopes": [
          "ALL_SCOPES"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "number",
      "$value": "{Radius.600}"
    },
    "layer-xl": {
      "$extensions": {
        "com.figma.scopes": [
