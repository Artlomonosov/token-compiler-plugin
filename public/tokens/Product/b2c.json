  "Padding": {
    "control-m": {
      "$extensions": {
        "com.figma.scopes": [
          "ALL_SCOPES"
        ],
        "com.figma.hiddenFromPublishing": false
      },
      "$type": "number",
      "$value": "{Paddings.md}"
