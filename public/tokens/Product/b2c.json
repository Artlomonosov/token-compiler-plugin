{
  "base": {
    "$extensions": {
      "com.figma.scopes": [
        "ALL_SCOPES"
      ],
      "com.figma.hiddenFromPublishing": false
    },
    "$type": "color",
    "$value": "{b2c.base}"
  },
  "brand": {
    "$extensions": {
      "com.figma.scopes": [
        "ALL_SCOPES"
      ],
      "com.figma.hiddenFromPublishing": false
    },
    "$type": "color",
    "$value": "{Color.Yellow.500}"
  },
  "text-onbrand": {
    "$extensions": {
      "com.figma.scopes": [
        "ALL_SCOPES"
      ],
      "com.figma.hiddenFromPublishing": false
    },
    "$type": "color",
    "$value": "{Color.Black.100%}"
  },
  "bg-brand-secondary": {
    "$extensions": {
      "com.figma.scopes": [
        "ALL_SCOPES"
      ],
      "com.figma.hiddenFromPublishing": false
    },
    "$type": "color",
    "$value": "{b2c.bg-brand-secondary}"
  },
  "text-brand": {
    "$extensions": {
      "com.figma.scopes": [
        "ALL_SCOPES"
      ],
      "com.figma.hiddenFromPublishing": false
    },
    "$type": "color",
    "$value": "{b2c.text-brand-secondary}"
  },
  "bg-layer-first": {
    "$extensions": {
      "com.figma.scopes": [
        "ALL_SCOPES"
      ],
      "com.figma.hiddenFromPublishing": false
